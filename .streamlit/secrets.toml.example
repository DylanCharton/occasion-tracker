# Exemple de secrets pour Streamlit Cloud.
# Copier dans le dashboard Streamlit Cloud (Settings > Secrets) — ne PAS committer le vrai fichier.
#
# En local, ces valeurs peuvent aussi être placées dans `.env` (même hiérarchie).

# --- Base de données Supabase ---------------------------------------------
# Transaction pooler (port 6543) conseillé pour Streamlit Cloud.
# Ajouter +psycopg2 après postgresql (driver SQLAlchemy).
# Format : postgresql+psycopg2://postgres.<project-ref>:<password>@aws-X-region.pooler.supabase.com:6543/postgres
DATABASE_URL = "postgresql+psycopg2://postgres.xxxx:YOUR_PASSWORD@aws-0-eu-west-3.pooler.supabase.com:6543/postgres"

# --- Discord (fallback admin) ---------------------------------------------
# Webhook utilisé si un user n'a pas configuré le sien. Vide si chaque user gère son canal.
DISCORD_WEBHOOK_URL = ""

# --- Auth / multi-user ----------------------------------------------------
# Exiger l'authentification Google (true en prod, false en dev local).
REQUIRE_AUTH = true

# Liste CSV des emails admins (reçoivent is_admin=True à la connexion).
ADMIN_EMAILS = "d.charton@fimainfo.fr"

# Whitelist CSV des emails autorisés à se connecter (famille/amis).
# Vide = toute personne loggée via Google est acceptée (déconseillé).
ALLOWED_EMAILS = "d.charton@fimainfo.fr,proche1@gmail.com,proche2@gmail.com"

# Email fallback en dev local sans SSO.
DEV_USER_EMAIL = "d.charton@fimainfo.fr"

# Email virtuel du user "démo" readonly (?demo=1).
DEMO_USER_EMAIL = "demo@local"

# --- Auth OIDC Google (requis si REQUIRE_AUTH=true) -----------------------
# 1. Google Cloud Console > APIs & Services > Credentials > OAuth client ID (Web app)
# 2. Authorized redirect URI : https://<ton-app>.streamlit.app/oauth2callback
# 3. Coller ici client_id + client_secret.
# 4. cookie_secret : chaîne aléatoire longue (ex: `python -c "import secrets;print(secrets.token_hex(32))"`)
[auth]
redirect_uri = "https://<ton-app>.streamlit.app/oauth2callback"
cookie_secret = "REMPLACER_PAR_UNE_CHAINE_ALEATOIRE_LONGUE"

[auth.google]
client_id = "xxxxxxxxxxxx.apps.googleusercontent.com"
client_secret = "GOCSPX-xxxxxxxxxxxxxxxxxxx"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
