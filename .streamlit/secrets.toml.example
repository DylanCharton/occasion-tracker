# Exemple de secrets pour Streamlit Cloud.
# Copier dans le dashboard Streamlit Cloud (Settings > Secrets) — ne PAS committer le vrai fichier.
#
# En local, ces valeurs peuvent aussi être placées dans `.env` (même hiérarchie) :
#   DATABASE_URL, DISCORD_WEBHOOK_URL, ADMIN_EMAILS, DEV_USER_EMAIL

# --- Base de données Supabase ---------------------------------------------
# Utiliser la connexion "Session pooler" de Supabase (port 5432) → supporte les
# prepared statements de SQLAlchemy. Récupérer depuis Supabase > Settings > Database > Connection string.
#
# Format : postgresql+psycopg2://postgres.<project-ref>:<password>@aws-X-region.pooler.supabase.com:5432/postgres
DATABASE_URL = "postgresql+psycopg2://postgres.xxxx:YOUR_PASSWORD@aws-0-eu-west-3.pooler.supabase.com:5432/postgres"

# --- Discord (fallback admin) ---------------------------------------------
# Webhook utilisé si un user n'a pas configuré le sien. Laisser vide si chaque user gère son canal.
DISCORD_WEBHOOK_URL = ""

# --- Auth / multi-user ----------------------------------------------------
# Liste CSV des emails qui auront is_admin=True à la première connexion.
ADMIN_EMAILS = "d.charton@fimainfo.fr"

# Email fallback si l'auth Streamlit n'est pas active (dev local sans Viewer auth).
# En prod Cloud : sera ignoré dès que st.user.email est renseigné par Google SSO.
DEV_USER_EMAIL = "d.charton@fimainfo.fr"
