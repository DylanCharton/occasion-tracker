# Webhook Discord (laisser vide pour désactiver les notifications)
DISCORD_WEBHOOK_URL=

# Rafraîchissement
DEFAULT_REFRESH_INTERVAL_HOURS=6

# Rate-limit (respect du site)
REQUEST_DELAY_SECONDS=1.5
REQUEST_JITTER_SECONDS=0.3
REQUEST_TIMEOUT_SECONDS=20
MAX_RETRIES=3

# Identification scraper
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 EasycashTrackerPerso/1.0

# Base de données (SQLite locale)
DATABASE_URL=sqlite:///data/easycash.db

# Logs
LOG_LEVEL=INFO
LOG_FILE=logs/scraper.log

# Seuil par défaut de détection de baisse (en pourcentage, ex: 0.05 = 5%)
DEFAULT_PRICE_DROP_THRESHOLD=0.05
